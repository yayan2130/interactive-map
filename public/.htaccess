# Served by Apache (XAMPP) from htdocs/interactive-map/.
# This file is copied into dist/ on every `npm run build`.

# Apache must label the PWA manifest correctly or some browsers ignore it.
AddType application/manifest+json .webmanifest

<IfModule mod_headers.c>
  # The service worker and live census data must never be cached by Apache,
  # otherwise app updates and activity cycles go stale.
  <FilesMatch "(sw\.js|census\.json)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>
